# Copy this file to `.env` in the same folder and fill in your keys.
# The app loads `.env` locally; this file is safe to commit (no secrets).
# See server/index.ts and https://github.com/motdotla/dotenv
#
# Required: ElevenLabs API key (music compose). Get one from your ElevenLabs dashboard.
ELEVENLABS_API_KEY=

# Optional: OpenAI API key — enriches the book title into a better ambient prompt + wireframe RGB.
OPENAI_API_KEY=

# Server port for /api (Vite proxies here in dev)
PORT=3001
